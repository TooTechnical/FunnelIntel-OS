# FunnelIntel OS — Environment Variables
# Copy this file to .env and fill in all values before running the app.

# ─── Database ────────────────────────────────────────────────────────────────
# MySQL / TiDB connection string
DATABASE_URL=mysql://user:password@host:3306/funnelintel

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Your Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from your Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard (create one product per plan)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ─── App ─────────────────────────────────────────────────────────────────────
# The Manus OpenID of the account that should receive admin role
OWNER_OPEN_ID=your-manus-open-id

# ─── Optional Analytics ──────────────────────────────────────────────────────
# Umami analytics (leave blank to disable)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
